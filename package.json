{
    "name": "nmbench",
    "displayName": "nmbench",
    "description": "VS Code extension for NONMEM run management",
    "author": {
        "name": "Woojin Jung"
    },
    "categories": [
        "Other"
    ],
    "icon": "resources/logo.png",
    "publisher": "tnzo12",
    "version": "0.3.3",
    "engines": {
        "vscode": "^1.93.0"
    },
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "extension.toggleHideModelFitDirs",
                "title": "Hide “modelfit_dir” folders",
                "category": "nmbench",
                "icon": "$(eye)"
            },
            {
                "command": "extension.readNmTableAndPlot",
                "title": "Data inspection",
                "icon": {
                    "dark": "./resources/dark/graph.svg",
                    "light": "./resources/light/graph.svg"
                }
            },
            {
                "command": "extension.showHistogram",
                "title": "Histogram",
                "icon": {
                    "dark": "./resources/dark/hist.svg",
                    "light": "./resources/light/hist.svg"
                }
            },
            {
                "command": "extension.readExtFile",
                "title": "Output",
                "icon": {
                    "dark": "./resources/dark/inspect.svg",
                    "light": "./resources/light/inspect.svg"
                }
            },
            {
                "command": "extension.manageRScriptCommand",
                "title": "Show R Scripts"
            },
            {
                "command": "extension.openModFile",
                "title": "Open Mod File"
            },
            {
                "command": "extension.showModFileContextMenu",
                "title": "PsN tools",
                "icon": {
                    "dark": "./resources/dark/psn.svg",
                    "light": "./resources/light/psn.svg"
                }
            },
            {
                "command": "extension.showModFileContextMenuFromTreeView",
                "title": "Run PsN tool",
                "icon": {
                    "dark": "./resources/dark/psn.svg",
                    "light": "./resources/light/psn.svg"
                }
            },
            {
                "command": "extension.runUpdateInits",
                "title": "Update inits"
            },
            {
                "command": "extension.deleteModelFiles",
                "title": "Delete with outputs"
            },
            {
                "command": "extension.showModFileContextMenuNONMEM",
                "title": "Run NONMEM command",
                "icon": {
                    "dark": "./resources/dark/nonmem.svg",
                    "light": "./resources/light/nonmem.svg"
                }
            },
            {
                "command": "extension.watchLiveExt",
                "title": "Monitor estimation",
                "icon": {
                    "dark": "./resources/dark/monitor.svg",
                    "light": "./resources/light/monitor.svg"
                }
            },
            {
                "command": "extension.showRScriptCommandFromEditor",
                "title": "Run R script",
                "icon": {
                    "dark": "./resources/dark/r.svg",
                    "light": "./resources/light/r.svg"
                }
            },
            {
                "command": "extension.showRScriptCommandFromTreeView",
                "title": "Run R script"
            },
            {
                "command": "extension.showLinkedFiles",
                "title": "Show related Files",
                "icon": {
                    "dark": "./resources/dark/link.svg",
                    "light": "./resources/light/link.svg"
                }
            },
            {
                "command": "extension.refreshModFileViewer",
                "title": "Refresh",
                "icon": {
                    "dark": "./resources/dark/refresh.svg",
                    "light": "./resources/light/refresh.svg"
                }
            },
            {
                "command": "extension.showHeatmap",
                "title": "Show Heatmap",
                "icon": {
                    "dark": "./resources/dark/mat.svg",
                    "light": "./resources/light/mat.svg"
                }
            },
            {
                "command": "extension.readExtFileFromActive",
                "title": "Output",
                "icon": {
                    "dark": "./resources/dark/inspect.svg",
                    "light": "./resources/light/inspect.svg"
                }
            },
            {
                "command": "extension.showLinkedPlotFromActive",
                "title": "Plot Table",
                "icon": {
                    "dark": "./resources/dark/graph.svg",
                    "light": "./resources/light/graph.svg"
                }
            },
            {
                "command": "extension.showLinkedHistogramFromActive",
                "title": "Histogram Table",
                "icon": {
                    "dark": "./resources/dark/hist.svg",
                    "light": "./resources/light/hist.svg"
                }
            },
            {
                "command": "extension.showHeatmapFromActive",
                "title": "Show Heatmap",
                "icon": {
                    "dark": "./resources/dark/mat.svg",
                    "light": "./resources/light/mat.svg"
                }
            },
            {
                "command": "extension.snapshotEstimatesView",
                "title": "Snapshot Estimates",
                "icon": {
                    "dark": "./resources/dark/snapshot.svg",
                    "light": "./resources/light/snapshot.svg"
                }
            },
            {
                "command": "extension.openNmbenchSettings",
                "title": "Open nmbench Settings",
                "category": "nmbench",
                "icon": "$(gear)"
            }
        ],
        "keybindings": [
            {
                "command": "extension.showLinkedFiles",
                "key": "cmd+alt+R"
            },
            {
                "command": "extension.showModFileContextMenuFromTreeView",
                "key": "alt+E"
            },
            {
                "command": "extension.showRScriptCommandFromTreeView",
                "key": "alt+R"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "modelDevelopment",
                    "title": "Model Development",
                    "icon": "resources/model-development.svg"
                }
            ]
        },
        "views": {
            "explorer": [
                {
                    "id": "modFileViewer",
                    "name": "nmbench: Browser"
                },
                {
                    "id": "estimatesView",
                    "name": "nmbench: Estimates",
                    "type": "webview"
                }
            ],
            "modelDevelopment": [
                {
                    "id": "modelBuilderView",
                    "name": "nmbench: Model Builder",
                    "type": "webview"
                },
                {
                    "id": "amdView",
                    "name": "nmbench: AMD Script Generator",
                    "type": "webview"
                }
            ]
        },
        "configuration": {
            "title": "nmbench",
            "properties": {
                "nmbench.modFileViewer.hideModelFitDirs": {
                    "type": "boolean",
                    "default": false,
                    "description": "Hide folders whose name includes 'modelfit_dir' in the Mod File Viewer."
                },
                "nmbench.browser.fileExtensions": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": ["mod", "ctl"],
                    "markdownDescription": "File extensions shown in the **NMBENCH: BROWSER** tree view. Enter without the leading dot (e.g., `mod`, `ctl`, `mdl`). Changes take effect after the tree view refreshes."
                },
                "nmbench.nonmem.executablePath": {
                    "type": "string",
                    "default": "/opt/nm75/util/nmfe75",
                    "markdownDescription": "Path to the NONMEM executable (`nmfe*`). Used as the default when running NONMEM from a `.mod`/`.ctl` file. Examples: `/opt/nm75/util/nmfe75` on Linux/macOS, `C:\\nm75\\util\\nmfe75.bat` on Windows."
                }
            }
        },
        "menus": {
            "view/item/context": [
                {
                    "command": "extension.showModFileContextMenuFromTreeView",
                    "when": "viewItem == modFile",
                    "group": "1.PsN operations"
                },
                {
                    "command": "extension.runUpdateInits",
                    "when": "viewItem == modFile",
                    "group": "1.PsN operations"
                },
                {
                    "command": "extension.showLinkedFiles",
                    "when": "viewItem == modFile",
                    "group": "2.Navigation"
                },
                {
                    "command": "extension.showRScriptCommandFromTreeView",
                    "when": "viewItem == modFile || viewItem == modFolder",
                    "group": "3.Rscript operations"
                },
                {
                    "command": "extension.manageRScriptCommand",
                    "when": "viewItem == modFile || viewItem == modFolder",
                    "group": "3.Rscript operations"
                },
                {
                    "command": "extension.deleteModelFiles",
                    "when": "viewItem == modFile",
                    "group": "9.Delete"
                }
            ],
            "view/title": [
                {
                    "command": "extension.openNmbenchSettings",
                    "when": "view == modFileViewer",
                    "group": "navigation@1"
                },
                {
                    "command": "extension.watchLiveExt",
                    "when": "view == modFileViewer",
                    "group": "navigation@2"
                },
                {
                    "command": "extension.toggleHideModelFitDirs",
                    "when": "view == modFileViewer",
                    "group": "navigation@3",
                    "toggled": "config.nmbench.modFileViewer.hideModelFitDirs"
                },
                {
                    "command": "extension.refreshModFileViewer",
                    "when": "view == modFileViewer",
                    "group": "navigation@99"
                },
                {
                    "command": "extension.showLinkedFiles",
                    "when": "view == estimatesView",
                    "group": "navigation"
                },
                {
                    "command": "extension.showHeatmapFromActive",
                    "when": "view == estimatesView",
                    "group": "navigation"
                },
                {
                    "command": "extension.showLinkedPlotFromActive",
                    "when": "view == estimatesView",
                    "group": "navigation"
                },
                {
                    "command": "extension.showLinkedHistogramFromActive",
                    "when": "view == estimatesView",
                    "group": "navigation"
                },
                {
                    "command": "extension.snapshotEstimatesView",
                    "when": "view == estimatesView",
                    "group": "navigation"
                }
            ],
            "editor/title": [
                {
                    "command": "extension.readNmTableAndPlot",
                    "when": "resourceFilename =~ /(tab|table)/gi",
                    "group": "navigation"
                },
                {
                    "command": "extension.showHistogram",
                    "when": "resourceFilename =~ /(tab|table)/gi || resourceExtname == .phi",
                    "group": "navigation"
                },
                {
                    "command": "extension.readExtFile",
                    "when": "resourceFilename =~ /(tab|table)/gi || resourceExtname == .ext",
                    "group": "navigation"
                },
                {
                    "command": "extension.showModFileContextMenuNONMEM",
                    "when": "resourceExtname == .mod || resourceExtname == .ctl",
                    "group": "navigation"
                },
                {
                    "command": "extension.showModFileContextMenu",
                    "when": "resourceExtname == .mod || resourceExtname == .ctl",
                    "group": "navigation"
                },
                {
                    "command": "extension.showRScriptCommandFromEditor",
                    "when": "resourceExtname == .mod || resourceExtname == .ctl",
                    "group": "navigation"
                },
                {
                    "command": "extension.showHeatmap",
                    "when": "resourceExtname == .cov || resourceExtname == .coi || resourceExtname == .cor  || resourceExtname == .phi",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "command": "extension.readExtFile",
                    "when": "resourceExtname == .mod || resourceExtname == .ctl",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.6",
        "@types/node": "18.x",
        "@types/vscode": "^1.93.0",
        "@typescript-eslint/eslint-plugin": "^7.7.1",
        "@typescript-eslint/parser": "^7.7.1",
        "@vscode/test-cli": "^0.0.9",
        "@vscode/test-electron": "^2.3.9",
        "eslint": "^8.57.0",
        "typescript": "^5.4.5"
    },
    "license": "https://github.com/tnzo12/nmbench/blob/main/LICENSE",
    "bugs": {
        "url": "https://github.com/tnzo12/nmbench/issues",
        "email": "tnzo12@hotmail.com"
    },
    "homepage": "https://github.com/tnzo12/nmbench"
}
